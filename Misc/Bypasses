local HttpService = game:GetService("HttpService")

local folder_url = "https://api.github.com/repos/TheRealXORA/Roblox/contents/Scripts%20/Anti-Cheats%20Bypassers%20"

local function run_bypassers()
    local success, response = pcall(function()
        return game:HttpGet(folder_url)
    end)

    if not success then return end

    local data = HttpService:JSONDecode(response)

    for i, file in pairs(data) do
        if file.download_url then
            task.spawn(function()
                local script_data = game:HttpGet(file.download_url)
                local load_func = loadstring(script_data)
                
                if load_func then
                    load_func()
                end
            end)
        end
    end
end

run_bypassers()
